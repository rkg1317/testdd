# ---------------------------------------------------------------------------
# Model ring config — "swap the URL" portability.
# Copy to .env and fill in. The SAME workflow runs across rings by changing only
# these values. NEVER commit a real key; NEVER point DEV at real data.
# ---------------------------------------------------------------------------

# DEV ring  : an external open-model aggregator's OpenAI-compatible endpoint
#             (free/cheap OPEN models, SYNTHETIC DATA ONLY).
# OFFICE    : the in-house OpenAI-compatible gateway (swap base_url + key only).
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-me
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Embeddings (for the memo retrieval index). DEV: a local/free endpoint;
# OFFICE: the in-house embeddings endpoint. OpenAI-compatible base URL.
EMBEDDINGS_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDINGS_MODEL=nomic-embed-text

# Parser sidecar (this service) — where the Dify HTTP Request node reaches it.
PARSER_SERVICE_URL=http://host.docker.internal:8000
