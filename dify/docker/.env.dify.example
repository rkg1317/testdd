# ---------------------------------------------------------------------------
# Dify stack .env template
# ---------------------------------------------------------------------------
# USAGE: copy this file to .env and fill in the placeholder values.
#   cp .env.dify.example .env
#
# SECURITY RULES:
#   - The real .env (with actual keys) MUST NEVER be committed to git.
#     Ensure dify/docker/.env is listed in .gitignore.
#   - FORCE_VERIFYING_SIGNATURE=false is for the OFFLINE INSTALL TEST ONLY.
#     Set it back to true (or remove) before any production/office use.
#   - Never put real data files near a machine configured with an external
#     API key (OpenRouter is for synthetic data / DEV ring only).
# ---------------------------------------------------------------------------

# --- Required: Dify core secrets -----------------------------------------

# 32+ random characters.  Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Admin password set on first login.
INIT_PASSWORD=

# --- Offline plugin install flags ----------------------------------------
# Required when installing a repackaged .difypkg with network severed.
# Allows plugin_daemon to accept unsigned / locally-repackaged plugin bundles.
# REVERT TO true (or remove these lines) before any production deployment.

FORCE_VERIFYING_SIGNATURE=false
PLUGIN_MAX_PACKAGE_SIZE=524288000

# Nginx body size — must accommodate large .difypkg uploads.
NGINX_CLIENT_MAX_BODY_SIZE=500M

# --- DEV model ring (OpenAI-compatible endpoint) -------------------------
# Configure the model provider in Dify UI after starting the stack:
#   Settings → Model Provider → OpenAI-API-Compatible → Add Model
#   Base URL:  https://openrouter.ai/api/v1
#   API Key:   <your OpenRouter key>
#   Model:     meta-llama/llama-3.3-70b-instruct:free
#
# Swap to the OFFICE ring by changing only Base URL + API Key + Model Name
# in the Dify UI — no workflow edits needed.
#
# Uncomment the lines below if using the legacy built-in provider path
# instead of the UI plugin:
#
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=replace-me
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Fallback models if the primary model does not support tool-calling:
#   google/gemma-4-31b-it:free
#   qwen/qwen3-next-80b-a3b-instruct:free
